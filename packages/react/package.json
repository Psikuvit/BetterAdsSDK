{
  "name": "@betterads/react",
  "version": "0.1.0",
  "description": "React wrapper around @betterads/sdk-core: an <AdPlayer /> component.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@betterads/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "tsup": "^8.3.5"
  }
}
